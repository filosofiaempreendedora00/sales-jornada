{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Jornada Turbo (Python static server)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Jornada Turbo (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "8081", "--no-clipboard"],
      "port": 8081
    }
  ]
}
